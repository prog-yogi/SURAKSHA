generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                     String   @id @default(cuid())
  email                  String   @unique
  passwordHash           String
  name                   String
  role                   String
  lat                    Float?
  lng                    Float?
  address                String?
  status                 String   @default("SAFE")
  kycStatus              String   @default("Pending")
  locationTrackingStatus String   @default("Pending")

  // New registration fields
  phone                       String?
  alternativePhone            String?
  citizenship                 String?
  aadhaarNumber               String?
  emergencyContactName        String?
  emergencyContactPhone       String?
  emergencyContactRelation    String?

  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  emergencies            EmergencyEvent[]
  firs                   FIR[]
}

model EmergencyEvent {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lat       Float?
  lng       Float?
  accuracy  Float?
  stepsJson String   @default("[\"pending\",\"pending\",\"pending\",\"pending\"]")
  resolved  Boolean  @default(false)
  createdAt DateTime @default(now())
}

model ContactMessage {
  id           String   @id @default(cuid())
  firstName    String
  lastName     String
  email        String
  organization String
  message      String
  createdAt    DateTime @default(now())
}

model SystemActivity {
  id        String   @id @default(cuid())
  message   String
  kind      String
  detail    String?
  createdAt DateTime @default(now())
}

// IncidentType values: THEFT, ASSAULT, CYBERCRIME, HARASSMENT, ROBBERY, OTHER
// Stored as String because SQLite does not support enums.

model FIR {
  id               String       @id @default(cuid())
  firNumber        String       @unique
  userId           String
  complainantName  String
  complainantAddress String?
  complainantContact String?
  incidentType     String
  incidentDateTime DateTime
  location         String
  description      String
  accusedDetails   String?
  evidenceUrls     String?
  status           String       @default("PENDING")
  otpCode          String?
  otpSentAt        DateTime?
  verifiedAt       DateTime?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  user             User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  otp              Otp?

  @@map("firs")
}

model Otp {
  id        String   @id @default(cuid())
  firId     String   @unique
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  fir       FIR      @relation(fields: [firId], references: [id], onDelete: Cascade)
}

